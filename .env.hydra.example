# Copy this file to .env.hydra and adjust as needed for your local machine.
# If Postgres is bound to localhost only, use 15432 with scripts/start_pg_forwarder.sh.
DSN=postgres://raj@host.docker.internal:5432/hydra_db?sslmode=disable
URLS_SELF_ISSUER=http://localhost:4444/
URLS_LOGIN=http://localhost:3000/login
URLS_CONSENT=http://localhost:3000/consent
URLS_LOGOUT=http://localhost:3000/logout
SECRETS_SYSTEM=replace-with-a-long-random-dev-secret
OIDC_SUBJECT_IDENTIFIERS_SUPPORTED_TYPES=public
SERVE_PUBLIC_PORT=4444
SERVE_ADMIN_PORT=4445
LOG_LEVEL=debug
