APP_ENV=production
LOG_LEVEL=INFO

# Required in production
DATABASE_URL=postgresql+psycopg://agent_idp:change-me@postgres:5432/agent_idp
ADMIN_API_KEY=replace-with-strong-admin-key
INTERNAL_API_KEY=replace-with-strong-internal-key
AGENT_IDP_SIGNING_KEY_KID=cap-key-2026-01

# Ed25519 private key PEM (single-line with \n escapes if needed)
AGENT_IDP_SIGNING_KEY_PEM=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----

AGENT_IDP_ISSUER=https://idp.example.com
AGENT_TOKEN_AUDIENCE=agent-idp-platform
CAPABILITY_TOKEN_AUDIENCE=tool-gateway
AGENT_TOKEN_TTL_SECONDS=900
CAPABILITY_TOKEN_TTL_SECONDS=300

# Optional
# OPA_URL=http://opa:8181
